# FortiManager connection settings
FMG_HOST=https://fortimanager.example.com
FMG_PORT=443
FMG_API_TOKEN=your-api-token-here
FMG_VERIFY_SSL=true

# API version (7.4 or 7.6)
FMG_API_VERSION=7.6

# MCP transport mode (http or stdio)
MCP_TRANSPORT=stdio

# HTTP transport settings (only used when MCP_TRANSPORT=http)
MCP_HTTP_PORT=8000
